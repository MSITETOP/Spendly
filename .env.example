# Скопируйте в .env и укажите ключ: https://platform.openai.com/api-keys
# В Streamlit Community Cloud задайте те же переменные в Settings → Secrets (TOML).
OPENAI_API_KEY=sk-...
# Обязательный список кодовых слов для входа (через запятую)
SPENDLY_AUTH_CODES=kirill,anna
# Опционально: путь к общей БД (сетевая папка, Syncthing и т.д.)
# SPENDLY_DB_PATH=/path/to/shared/spendly.db
